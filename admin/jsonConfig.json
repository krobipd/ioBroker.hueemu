{
  "i18n": true,
  "type": "tabs",
  "items": {
    "networkTab": {
      "type": "panel",
      "label": "networkSettings",
      "items": {
        "serverHeader": {
          "type": "header",
          "text": "serverSettings",
          "size": 4
        },
        "host": {
          "type": "ip",
          "label": "host",
          "tooltip": "hostTooltip",
          "onlyIp4": true,
          "noInternal": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "port": {
          "type": "number",
          "label": "port",
          "tooltip": "portTooltip",
          "min": 1,
          "max": 65535,
          "default": 8080,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },

        "advancedHeader": {
          "newLine": true,
          "type": "header",
          "text": "advancedSettings",
          "size": 5
        },
        "advancedInfo": {
          "type": "staticText",
          "text": "advancedInfo",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontSize": 12,
            "marginBottom": 8
          }
        },
        "httpsPort": {
          "type": "number",
          "label": "httpsPort",
          "tooltip": "httpsPortTooltip",
          "min": 1,
          "max": 65535,
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "mac": {
          "type": "text",
          "label": "mac",
          "tooltip": "macTooltip",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "trustProxy": {
          "newLine": true,
          "type": "checkbox",
          "label": "trustProxy",
          "tooltip": "trustProxyTooltip",
          "default": false,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },

        "_supportHeader": {
          "newLine": true,
          "type": "header",
          "text": "supportHeader",
          "size": 5
        },
        "_aboutInfo": {
          "type": "staticText",
          "text": "aboutInfo",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontSize": 14,
            "marginBottom": 16
          }
        },
        "_kofiLink": {
          "type": "staticLink",
          "href": "https://ko-fi.com/krobipd",
          "label": "donateKofi",
          "button": true,
          "variant": "outlined",
          "color": "primary",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "_paypalLink": {
          "type": "staticLink",
          "href": "https://paypal.me/krobipd",
          "label": "donatePaypal",
          "button": true,
          "variant": "outlined",
          "color": "primary",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        }
      }
    },

    "devicesTab": {
      "type": "panel",
      "label": "deviceConfiguration",
      "items": {
        "devicesInfo": {
          "type": "staticText",
          "text": "deviceConfigHelp",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontSize": 14,
            "marginBottom": 16
          }
        },
        "devicesHeader": {
          "type": "header",
          "text": "configuredDevices",
          "size": 4
        },
        "devices": {
          "type": "accordion",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "titleAttr": "name",
          "items": [
            {
              "attr": "name",
              "type": "text",
              "label": "deviceName",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6,
              "default": "New Light"
            },
            {
              "attr": "lightType",
              "type": "select",
              "label": "lightType",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6,
              "default": "dimmable",
              "options": [
                { "label": "lightTypeOnOff", "value": "onoff" },
                { "label": "lightTypeDimmable", "value": "dimmable" },
                { "label": "lightTypeCT", "value": "ct" },
                { "label": "lightTypeColor", "value": "color" }
              ]
            },
            {
              "attr": "onState",
              "type": "objectId",
              "label": "stateOn",
              "tooltip": "stateOnTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6
            },
            {
              "attr": "briState",
              "type": "objectId",
              "label": "stateBri",
              "tooltip": "stateBriTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 4,
              "lg": 4,
              "xl": 4,
              "hidden": "data.lightType === 'onoff'"
            },
            {
              "attr": "briScale",
              "type": "select",
              "label": "scaleBri",
              "tooltip": "scaleTooltip",
              "default": "auto",
              "options": [
                { "label": "scaleAuto", "value": "auto" },
                { "label": "scalePercent", "value": "percent" },
                { "label": "scaleNormalized", "value": "normalized" },
                { "label": "scaleRaw", "value": "raw" }
              ],
              "xs": 12,
              "sm": 12,
              "md": 2,
              "lg": 2,
              "xl": 2,
              "hidden": "data.lightType === 'onoff'"
            },
            {
              "attr": "ctState",
              "type": "objectId",
              "label": "stateCt",
              "tooltip": "stateCtTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6,
              "hidden": "data.lightType !== 'ct' && data.lightType !== 'color'"
            },
            {
              "attr": "hueState",
              "type": "objectId",
              "label": "stateHue",
              "tooltip": "stateHueTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6,
              "hidden": "data.lightType !== 'color'"
            },
            {
              "attr": "satState",
              "type": "objectId",
              "label": "stateSat",
              "tooltip": "stateSatTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 4,
              "lg": 4,
              "xl": 4,
              "hidden": "data.lightType !== 'color'"
            },
            {
              "attr": "satScale",
              "type": "select",
              "label": "scaleSat",
              "tooltip": "scaleTooltip",
              "default": "auto",
              "options": [
                { "label": "scaleAuto", "value": "auto" },
                { "label": "scalePercent", "value": "percent" },
                { "label": "scaleNormalized", "value": "normalized" },
                { "label": "scaleRaw", "value": "raw" }
              ],
              "xs": 12,
              "sm": 12,
              "md": 2,
              "lg": 2,
              "xl": 2,
              "hidden": "data.lightType !== 'color'"
            },
            {
              "attr": "xyState",
              "type": "objectId",
              "label": "stateXy",
              "tooltip": "stateXyTooltip",
              "types": "state",
              "xs": 12,
              "sm": 12,
              "md": 6,
              "lg": 6,
              "xl": 6,
              "hidden": "data.lightType !== 'color'"
            }
          ]
        }
      }
    }
  }
}
