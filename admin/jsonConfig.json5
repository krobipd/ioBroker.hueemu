{
    "i18n": true,
    "type": "tabs",
    "items": {
        // ============================================
        // TAB 1: Network Settings
        // ============================================
        "networkTab": {
            "type": "panel",
            "label": "networkSettings",
            "icon": "settings_ethernet",
            "items": {
                // Server Settings Section
                "serverHeader": {
                    "type": "header",
                    "text": "serverSettings",
                    "size": 4
                },
                "host": {
                    "type": "text",
                    "label": "host",
                    "tooltip": "hostTooltip",
                    "sm": 12,
                    "md": 4
                },
                "port": {
                    "type": "number",
                    "label": "port",
                    "tooltip": "portTooltip",
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },
                "httpsPort": {
                    "type": "number",
                    "label": "httpsPort",
                    "tooltip": "httpsPortTooltip",
                    "min": 1,
                    "max": 65535,
                    "placeholder": "optional",
                    "sm": 12,
                    "md": 4
                },

                // Discovery Settings Section
                "discoveryHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "discoverySettings",
                    "size": 4
                },
                "discoveryHost": {
                    "type": "text",
                    "label": "discoveryHost",
                    "tooltip": "discoveryHostTooltip",
                    "placeholder": "sameAsHost",
                    "sm": 12,
                    "md": 4
                },
                "discoveryPort": {
                    "type": "number",
                    "label": "discoveryPort",
                    "tooltip": "discoveryPortTooltip",
                    "min": 1,
                    "max": 65535,
                    "placeholder": "sameAsPort",
                    "sm": 12,
                    "md": 4
                },
                "upnpPort": {
                    "type": "number",
                    "label": "upnpPort",
                    "tooltip": "upnpPortTooltip",
                    "default": 1900,
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },

                // Bridge Identity Section
                "identityHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "bridgeIdentity",
                    "size": 4
                },
                "mac": {
                    "type": "text",
                    "label": "mac",
                    "tooltip": "macTooltip",
                    "placeholder": "AA:BB:CC:DD:EE:FF",
                    "sm": 12,
                    "md": 6
                },
                "udn": {
                    "type": "text",
                    "label": "udn",
                    "tooltip": "udnTooltip",
                    "placeholder": "autoGenerated",
                    "sm": 12,
                    "md": 6
                }
            }
        },

        // ============================================
        // TAB 2: Device Configuration
        // ============================================
        "devicesTab": {
            "type": "panel",
            "label": "deviceConfiguration",
            "icon": "devices",
            "items": {
                "devicesInfo": {
                    "type": "staticText",
                    "text": "deviceConfigHelp",
                    "style": {
                        "color": "gray",
                        "marginBottom": "16px"
                    }
                },
                "devices": {
                    "type": "table",
                    "sm": 12,
                    "label": "configuredDevices",
                    "showFirstAddOnTop": true,
                    "clone": true,
                    "items": [
                        {
                            "type": "text",
                            "attr": "name",
                            "title": "deviceName",
                            "width": "20%",
                            "default": "New Light"
                        },
                        {
                            "type": "select",
                            "attr": "lightType",
                            "title": "lightType",
                            "width": "15%",
                            "default": "color",
                            "options": [
                                {"label": "lightTypeOnOff", "value": "onoff"},
                                {"label": "lightTypeDimmable", "value": "dimmable"},
                                {"label": "lightTypeCT", "value": "ct"},
                                {"label": "lightTypeColor", "value": "color"}
                            ]
                        },
                        {
                            "type": "objectId",
                            "attr": "onState",
                            "title": "stateOn",
                            "width": "13%",
                            "filterTypes": ["state"]
                        },
                        {
                            "type": "objectId",
                            "attr": "briState",
                            "title": "stateBri",
                            "width": "13%",
                            "filterTypes": ["state"]
                        },
                        {
                            "type": "objectId",
                            "attr": "ctState",
                            "title": "stateCt",
                            "width": "13%",
                            "filterTypes": ["state"]
                        },
                        {
                            "type": "objectId",
                            "attr": "hueState",
                            "title": "stateHue",
                            "width": "13%",
                            "filterTypes": ["state"]
                        },
                        {
                            "type": "objectId",
                            "attr": "satState",
                            "title": "stateSat",
                            "width": "13%",
                            "filterTypes": ["state"]
                        }
                    ]
                }
            }
        }
    }
}
