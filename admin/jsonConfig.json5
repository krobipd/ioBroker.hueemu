{
    "i18n": true,
    "type": "tabs",
    "items": {
        "networkTab": {
            "type": "panel",
            "label": "networkSettings",
            "items": {
                "serverHeader": {
                    "type": "header",
                    "text": "serverSettings",
                    "size": 4
                },
                "host": {
                    "type": "text",
                    "label": "host",
                    "tooltip": "hostTooltip",
                    "sm": 12,
                    "md": 6
                },
                "port": {
                    "type": "number",
                    "label": "port",
                    "tooltip": "portTooltip",
                    "min": 1,
                    "max": 65535,
                    "default": 8080,
                    "sm": 12,
                    "md": 6
                },

                "advancedHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "advancedSettings",
                    "size": 5
                },
                "advancedInfo": {
                    "type": "staticText",
                    "text": "advancedInfo",
                    "style": {
                        "fontSize": 12,
                        "color": "#888",
                        "marginBottom": 8
                    }
                },
                "upnpPort": {
                    "type": "number",
                    "label": "upnpPort",
                    "tooltip": "upnpPortTooltip",
                    "default": 1900,
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },
                "httpsPort": {
                    "type": "number",
                    "label": "httpsPort",
                    "tooltip": "httpsPortTooltip",
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },
                "mac": {
                    "type": "text",
                    "label": "mac",
                    "tooltip": "macTooltip",
                    "sm": 12,
                    "md": 4
                }
            }
        },

        "devicesTab": {
            "type": "panel",
            "label": "deviceConfiguration",
            "items": {
                "devicesInfo": {
                    "type": "staticText",
                    "text": "deviceConfigHelp",
                    "style": {
                        "fontSize": 14,
                        "color": "#666",
                        "marginBottom": 16
                    }
                },
                "devicesHeader": {
                    "type": "header",
                    "text": "configuredDevices",
                    "size": 4
                },
                "devices": {
                    "type": "accordion",
                    "sm": 12,
                    "titleAttr": "name",
                    "items": [
                        {
                            "attr": "name",
                            "type": "text",
                            "label": "deviceName",
                            "sm": 12,
                            "md": 6,
                            "default": "New Light"
                        },
                        {
                            "attr": "lightType",
                            "type": "select",
                            "label": "lightType",
                            "sm": 12,
                            "md": 6,
                            "default": "dimmable",
                            "options": [
                                {"label": "lightTypeOnOff", "value": "onoff"},
                                {"label": "lightTypeDimmable", "value": "dimmable"},
                                {"label": "lightTypeCT", "value": "ct"},
                                {"label": "lightTypeColor", "value": "color"}
                            ]
                        },
                        {
                            "attr": "onState",
                            "type": "objectId",
                            "label": "stateOn",
                            "tooltip": "stateOnTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6
                        },
                        {
                            "attr": "briState",
                            "type": "objectId",
                            "label": "stateBri",
                            "tooltip": "stateBriTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType === 'onoff'"
                        },
                        {
                            "attr": "ctState",
                            "type": "objectId",
                            "label": "stateCt",
                            "tooltip": "stateCtTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'ct' && data.lightType !== 'color'"
                        },
                        {
                            "attr": "hueState",
                            "type": "objectId",
                            "label": "stateHue",
                            "tooltip": "stateHueTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        },
                        {
                            "attr": "satState",
                            "type": "objectId",
                            "label": "stateSat",
                            "tooltip": "stateSatTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        },
                        {
                            "attr": "xyState",
                            "type": "objectId",
                            "label": "stateXy",
                            "tooltip": "stateXyTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        }
                    ]
                }
            }
        }
    }
}
