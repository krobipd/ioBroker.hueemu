{
    "i18n": true,
    "type": "tabs",
    "items": {
        // ============================================
        // TAB 1: Network Settings
        // ============================================
        "networkTab": {
            "type": "panel",
            "label": "networkSettings",
            "icon": "settings_ethernet",
            "items": {
                // Server Settings Section
                "serverHeader": {
                    "type": "header",
                    "text": "serverSettings",
                    "size": 4
                },
                "host": {
                    "type": "text",
                    "label": "host",
                    "tooltip": "hostTooltip",
                    "sm": 12,
                    "md": 4
                },
                "port": {
                    "type": "number",
                    "label": "port",
                    "tooltip": "portTooltip",
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },
                "httpsPort": {
                    "type": "number",
                    "label": "httpsPort",
                    "tooltip": "httpsPortTooltip",
                    "min": 1,
                    "max": 65535,
                    "placeholder": "optional",
                    "sm": 12,
                    "md": 4
                },

                // Discovery Settings Section
                "discoveryHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "discoverySettings",
                    "size": 4
                },
                "discoveryHost": {
                    "type": "text",
                    "label": "discoveryHost",
                    "tooltip": "discoveryHostTooltip",
                    "placeholder": "sameAsHost",
                    "sm": 12,
                    "md": 4
                },
                "discoveryPort": {
                    "type": "number",
                    "label": "discoveryPort",
                    "tooltip": "discoveryPortTooltip",
                    "min": 1,
                    "max": 65535,
                    "placeholder": "sameAsPort",
                    "sm": 12,
                    "md": 4
                },
                "upnpPort": {
                    "type": "number",
                    "label": "upnpPort",
                    "tooltip": "upnpPortTooltip",
                    "default": 1900,
                    "min": 1,
                    "max": 65535,
                    "sm": 12,
                    "md": 4
                },

                // Bridge Identity Section
                "identityHeader": {
                    "newLine": true,
                    "type": "header",
                    "text": "bridgeIdentity",
                    "size": 4
                },
                "mac": {
                    "type": "text",
                    "label": "mac",
                    "tooltip": "macTooltip",
                    "placeholder": "AA:BB:CC:DD:EE:FF",
                    "sm": 12,
                    "md": 6
                },
                "udn": {
                    "type": "text",
                    "label": "udn",
                    "tooltip": "udnTooltip",
                    "placeholder": "autoGenerated",
                    "sm": 12,
                    "md": 6
                }
            }
        },

        // ============================================
        // TAB 2: Device Configuration
        // ============================================
        "devicesTab": {
            "type": "panel",
            "label": "deviceConfiguration",
            "icon": "devices",
            "items": {
                "devicesInfo": {
                    "type": "staticText",
                    "text": "deviceConfigHelp",
                    "style": {
                        "fontSize": 14,
                        "color": "#666",
                        "marginBottom": 16
                    }
                },

                // Quick Add from Room
                "quickAddHeader": {
                    "type": "header",
                    "text": "quickAdd",
                    "size": 5
                },
                "roomSelect": {
                    "type": "selectSendTo",
                    "label": "selectRoom",
                    "command": "getRooms",
                    "sm": 12,
                    "md": 5
                },
                "detectFromRoomBtn": {
                    "type": "sendTo",
                    "label": "detectFromRoom",
                    "command": "detectFromRoom",
                    "variant": "outlined",
                    "icon": "search",
                    "jsonData": "{\"enumId\": \"${data.roomSelect}\"}",
                    "sm": 12,
                    "md": 3
                },
                "divider1": {
                    "type": "divider",
                    "newLine": true
                },

                // Devices Accordion
                "devicesHeader": {
                    "type": "header",
                    "text": "configuredDevices",
                    "size": 4
                },
                "devices": {
                    "type": "accordion",
                    "sm": 12,
                    "titleAttr": "name",
                    "items": [
                        {
                            "attr": "name",
                            "type": "text",
                            "label": "deviceName",
                            "sm": 12,
                            "md": 6,
                            "default": "New Light"
                        },
                        {
                            "attr": "sourceOid",
                            "type": "objectId",
                            "label": "sourceObject",
                            "tooltip": "sourceObjectTooltip",
                            "sm": 12,
                            "md": 4
                        },
                        {
                            "type": "sendTo",
                            "label": "detect",
                            "command": "detectDevice",
                            "variant": "contained",
                            "color": "primary",
                            "icon": "search",
                            "jsonData": "{\"oid\": \"${data.sourceOid}\"}",
                            "sm": 12,
                            "md": 2
                        },
                        {
                            "attr": "lightType",
                            "type": "select",
                            "label": "lightType",
                            "sm": 12,
                            "md": 4,
                            "default": "color",
                            "options": [
                                {"label": "lightTypeOnOff", "value": "onoff"},
                                {"label": "lightTypeDimmable", "value": "dimmable"},
                                {"label": "lightTypeCT", "value": "ct"},
                                {"label": "lightTypeColor", "value": "color"}
                            ]
                        },
                        {
                            "attr": "detectedType",
                            "type": "text",
                            "label": "detectedType",
                            "disabled": true,
                            "sm": 12,
                            "md": 4,
                            "hidden": "!data.detectedType"
                        },
                        {
                            "type": "header",
                            "text": "stateMapping",
                            "size": 5,
                            "newLine": true
                        },
                        {
                            "type": "staticText",
                            "text": "stateMappingHelp",
                            "style": {
                                "fontSize": 12,
                                "color": "#888",
                                "marginBottom": 8
                            }
                        },
                        {
                            "attr": "onState",
                            "type": "objectId",
                            "label": "stateOn",
                            "tooltip": "stateOnTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6
                        },
                        {
                            "attr": "briState",
                            "type": "objectId",
                            "label": "stateBri",
                            "tooltip": "stateBriTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType === 'onoff'"
                        },
                        {
                            "attr": "ctState",
                            "type": "objectId",
                            "label": "stateCt",
                            "tooltip": "stateCtTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'ct' && data.lightType !== 'color'"
                        },
                        {
                            "attr": "hueState",
                            "type": "objectId",
                            "label": "stateHue",
                            "tooltip": "stateHueTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        },
                        {
                            "attr": "satState",
                            "type": "objectId",
                            "label": "stateSat",
                            "tooltip": "stateSatTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        },
                        {
                            "attr": "xyState",
                            "type": "objectId",
                            "label": "stateXy",
                            "tooltip": "stateXyTooltip",
                            "types": "state",
                            "sm": 12,
                            "md": 6,
                            "hidden": "data.lightType !== 'color'"
                        }
                    ]
                }
            }
        }
    }
}
