{
	"name": "iobroker.hueemu",
	"version": "1.0.4",
	"description": "Hue Bridge Emulator - Modernized 2026",
	"author": {
		"name": "Christopher Holomek",
		"email": "holomekc.github@gmail.com"
	},
	"contributors": [
		{
			"name": "krobi",
			"role": "Modernization & Optimization (2026)"
		},
		{
			"name": "AI Assistant",
			"role": "Architecture & Implementation Support (2026)"
		}
	],
	"homepage": "https://github.com/krobipd/ioBroker.hueemu",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"Hue",
		"Smart Home",
		"home automation"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/krobipd/ioBroker.hueemu"
	},
	"engines": {
		"node": ">=20",
		"npm": ">=10"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.3.2",
		"fastify": "^5.8.2",
		"node-forge": "^1.3.3",
		"node-ssdp": "^4.0.1",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@iobroker/eslint-config": "^2.2.0",
		"@iobroker/testing": "^5.2.2",
		"@types/chai": "^4.3.20",
		"@types/chai-as-promised": "^8.0.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.5.0",
		"@types/node-forge": "^1.3.14",
		"@types/node-ssdp": "^4.0.5",
		"@types/sinon": "^21.0.0",
		"@types/sinon-chai": "^4.0.0",
		"chai": "^6.2.2",
		"chai-as-promised": "^8.0.2",
		"eslint": "^10.0.3",
		"mocha": "^11.7.5",
		"sinon": "^21.0.3",
		"sinon-chai": "^3.7.0",
		"source-map-support": "^0.5.21",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	},
	"main": "build/main.js",
	"files": [
		"build/",
		"admin/",
		"io-package.json",
		"LICENSE"
	],
	"scripts": {
		"prepare": "test -d build || npm run build",
		"prebuild": "rm -rf ./build",
		"build:ts": "tsc -p tsconfig.build.json",
		"build": "npm run build:ts",
		"watch:ts": "tsc -p tsconfig.build.json --watch",
		"watch": "npm run watch:ts",
		"check": "tsc -p tsconfig.build.json --noEmit",
		"test:ts": "mocha --config test/.mocharc.json",
		"test:package": "mocha test/package --exit",
		"test:unit": "mocha test/unit --exit",
		"test:integration": "npm run build && mocha test/integration --exit",
		"test": "npm run test:ts && npm run test:package",
		"coverage": "nyc npm run test:ts",
		"check:structure": "bash ./scripts/check-structure.sh",
		"clean:project": "bash ./scripts/cleanup-project.sh",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"pack": "npm run build && npm pack",
		"version:patch": "node scripts/version.js patch",
		"version:minor": "node scripts/version.js minor",
		"version:major": "node scripts/version.js major",
		"release": "npm run build && npm run version:patch"
	},
	"nyc": {
		"include": [
			"src/**/*.ts"
		],
		"exclude": [
			"src/**/*.test.ts"
		],
		"extension": [
			".ts"
		],
		"require": [
			"ts-node/register"
		],
		"reporter": [
			"text-summary",
			"html",
			"lcov"
		],
		"sourceMap": true,
		"instrument": true
	},
	"bugs": {
		"url": "https://github.com/krobipd/ioBroker.hueemu/issues"
	},
	"readmeFilename": "README.md"
}
