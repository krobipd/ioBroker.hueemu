{
  "name": "iobroker.hueemu",
  "version": "1.0.26",
  "description": "Hue Bridge Emulator - Modernized 2026",
  "author": {
    "name": "Christopher Holomek",
    "email": "holomekc.github@gmail.com"
  },
  "contributors": [
    {
      "name": "krobi",
      "role": "Modernization & Optimization (2026)"
    },
    {
      "name": "AI Assistant",
      "role": "Architecture & Implementation Support (2026)"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.hueemu",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "Hue",
    "Smart Home",
    "home automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.hueemu"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "fastify": "^5.8.2",
    "node-forge": "^1.3.3",
    "node-ssdp": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "@types/node-ssdp": "^4.0.5",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2"
  },
  "main": "build/main.js",
  "files": [
    "build/",
    "admin/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "test -d build || npm run build",
    "prebuild": "rimraf build",
    "build:ts": "build-adapter ts",
    "build": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "build:test": "tsc -p tsconfig.test.json",
    "test:package": "npm run build:test && mocha --exit \"build/test/testPackageFiles.js\"",
    "test:integration": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "test": "npm run build:test && mocha --exit \"build/test/**/*.js\"",
    "check:structure": "bash ./scripts/check-structure.sh",
    "clean:project": "bash ./scripts/cleanup-project.sh",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "pack": "npm run build && npm pack",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.hueemu/issues"
  },
  "readmeFilename": "README.md"
}
