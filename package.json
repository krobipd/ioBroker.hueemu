{
  "name": "iobroker.hueemu",
  "version": "1.0.0",
  "description": "Hue Bridge Emulator - Modernized 2026",
  "author": {
    "name": "Christopher Holomek",
    "email": "holomekc.github@gmail.com"
  },
  "contributors": [
    {
      "name": "krobi",
      "role": "Modernization & Optimization (2026)"
    },
    {
      "name": "AI Assistant",
      "role": "Architecture & Implementation Support (2026)"
    }
  ],
  "homepage": "https://github.com/holomekc/ioBroker.hueemu",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "Hue",
    "Smart Home",
    "home automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/holomekc/ioBroker.hueemu"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.2",
    "rxjs": "^7.8.1",
    "hue-emu": "0.1.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@iobroker/testing": "^5.0.0",
    "@types/chai": "^4.3.19",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.7.5",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^3.2.12",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.7",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^9.12.0",
    "mocha": "^10.7.3",
    "nyc": "^17.1.0",
    "proxyquire": "^2.1.3",
    "rimraf": "^6.0.1",
    "sinon": "^19.0.2",
    "sinon-chai": "^3.7.0",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "main": "build/main.js",
  "files": [
    "build/",
    "admin/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf ./build",
    "build:ts": "tsc -p tsconfig.build.json",
    "build": "npm run build:ts",
    "watch:ts": "tsc -p tsconfig.build.json --watch",
    "watch": "npm run watch:ts",
    "test:ts": "mocha --config test/.mocharc.json",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "coverage": "nyc npm run test:ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "pack": "npm run build && npm pack",
    "release": "npm run build && npm version patch && npm publish"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html",
      "lcov"
    ],
    "sourceMap": true,
    "instrument": true
  },
  "bugs": {
    "url": "https://github.com/holomekc/ioBroker.hueemu/issues"
  },
  "readmeFilename": "README.md"
}
