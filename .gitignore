# ============================================
# .gitignore für ioBroker.hueemu
# ============================================

# Dependencies
node_modules/

# Build output
build/
dist/
*.js
*.js.map
*.d.ts
*.tsbuildinfo
!admin/*.js
!admin/**/*.js
!eslint.config.js
!scripts/*.js

# Tests & Coverage
coverage/
.nyc_output/
test-results/
*.lcov

# ============================================
# CHAOS VERHINDERN - Backup & Alte Dateien
# ============================================
*.old
*.backup
*.bak
*.tmp
*.temp
*~
*.orig
*.save
*.swp
*.swo

# macOS Duplikate (Finder-Kopien)
* 2.*
* 3.*
* copy.*
* Copy.*
*Kopie*

# Versionierte Duplikate
*-v1.*
*-v2.*
*-v3.*
*-backup-*
*-old-*

# Experimentelle Dateien
*-optimized.*
*-experimental.*
*-test.*
*-neu.*
*-alt.*

# ============================================
# Editor & IDE
# ============================================
.vscode/
.idea/

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# OS Generated
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.*.local

# ============================================
# ioBroker Specific
# ============================================
.dev-server/
admin/build/
admin/tmp/
.cleanup-backups/
backup-*.tar.gz
